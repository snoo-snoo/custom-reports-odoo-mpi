<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_report_branding" model="ir.ui.view">
        <field name="name">res.company.form.report.branding</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Report branding" name="report_branding" groups="base.group_system">
                    <group string="Apply branding on these reports">
                        <field name="crb_rpt_sale_order"/>
                        <field name="crb_rpt_stock_picking"/>
                        <field name="crb_rpt_purchase_order"/>
                        <field name="crb_rpt_customer_invoice"/>
                        <field name="crb_rpt_credit_note"/>
                        <field name="crb_rpt_vendor"/>
                        <field name="crb_rpt_other"/>
                    </group>
                    <group string="Letterhead">
                        <field name="crb_letterhead_pdf" filename="crb_letterhead_pdf_filename"/>
                        <field name="crb_letterhead_pdf_filename" invisible="1"/>
                        <field name="crb_use_letterhead"/>
                        <field name="crb_margin_top_mm"/>
                        <field name="crb_margin_bottom_mm"/>
                        <field name="crb_margin_left_mm"/>
                        <field name="crb_margin_right_mm"/>
                        <field name="crb_asset_token" readonly="1" groups="base.group_no_one"/>
                    </group>
                    <group string="Fonts">
                        <group string="Heading">
                            <field name="crb_font_heading_source"/>
                            <field name="crb_font_heading_google_family" invisible="crb_font_heading_source != 'google'"/>
                            <field name="crb_font_heading_file" filename="crb_font_heading_filename" invisible="crb_font_heading_source != 'upload'"/>
                            <field name="crb_font_heading_filename" invisible="1"/>
                        </group>
                        <group string="Body">
                            <field name="crb_font_body_source"/>
                            <field name="crb_font_body_google_family" invisible="crb_font_body_source != 'google'"/>
                            <field name="crb_font_body_file" filename="crb_font_body_filename" invisible="crb_font_body_source != 'upload'"/>
                            <field name="crb_font_body_filename" invisible="1"/>
                        </group>
                    </group>
                    <group string="Logo and footer">
                        <group>
                            <field name="crb_logo_mode"/>
                            <field name="crb_logo_custom" filename="crb_logo_custom_filename" invisible="crb_logo_mode != 'custom'"/>
                            <field name="crb_logo_custom_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="crb_footer_mode"/>
                            <field name="crb_footer_html" invisible="crb_footer_mode != 'custom'"/>
                        </group>
                    </group>
                    <group string="Default texts near line tables (HTML)">
                        <div colspan="2" class="text-muted">
                            Optional blocks printed on PDFs above / below the main product line table
                            (separate texts per document type; translatable).
                        </div>
                        <separator string="Sale orders &amp; quotations"/>
                        <field name="crb_line_note_sale_above" placeholder="Text above order lines…"/>
                        <field name="crb_line_note_sale_below" placeholder="Text below order lines…"/>
                        <separator string="Delivery slips / pickings"/>
                        <field name="crb_line_note_delivery_above" placeholder="Text above delivery lines…"/>
                        <field name="crb_line_note_delivery_below" placeholder="Text below delivery lines…"/>
                        <separator string="Purchase orders"/>
                        <field name="crb_line_note_purchase_above" placeholder="Text above PO lines…"/>
                        <field name="crb_line_note_purchase_below" placeholder="Text below PO lines…"/>
                        <separator string="Customer invoices"/>
                        <field name="crb_line_note_out_invoice_above" placeholder="Text above invoice lines…"/>
                        <field name="crb_line_note_out_invoice_below" placeholder="Text below invoice lines…"/>
                        <separator string="Customer credit notes"/>
                        <field name="crb_line_note_out_refund_above" placeholder="Text above credit note lines…"/>
                        <field name="crb_line_note_out_refund_below" placeholder="Text below credit note lines…"/>
                        <separator string="Vendor bills &amp; vendor credit notes"/>
                        <field name="crb_line_note_vendor_above" placeholder="Text above vendor document lines…"/>
                        <field name="crb_line_note_vendor_below" placeholder="Text below vendor document lines…"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
