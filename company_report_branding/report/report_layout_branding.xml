<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="crb_render_logo" name="CRB logo by mode">
        <t t-if="not crb_apply_branding">
            <img t-if="company.logo" t-attf-class="{{ logo_class }}" t-att-src="image_data_uri(company.logo)" alt="Logo"/>
        </t>
        <t t-else="">
            <img t-if="company.crb_logo_mode == 'standard' and company.logo"
                 t-attf-class="{{ logo_class }}"
                 t-att-src="image_data_uri(company.logo)" alt="Logo"/>
            <img t-elif="company.crb_logo_mode == 'custom' and company.crb_logo_custom"
                 t-attf-class="{{ logo_class }}"
                 t-att-src="image_data_uri(company.crb_logo_custom)" alt="Logo"/>
        </t>
    </template>

    <template id="crb_report_layout_head" inherit_id="web.report_layout">
        <xpath expr="//head" position="inside">
            <t t-out="crb_report_extra_head"/>
        </xpath>
    </template>

    <!-- external_layout_standard -->
    <template id="crb_external_layout_standard" inherit_id="web.external_layout_standard">
        <xpath expr="//img[hasclass('o_company_logo_small')]" position="replace">
            <t t-set="logo_class" t-value="'o_company_logo_small'"/>
            <t t-call="company_report_branding.crb_render_logo"/>
        </xpath>
        <xpath expr="//div[contains(@t-attf-class, 'o_report_layout_standard')]/t[last()]" position="replace">
            <t t-if="not crb_apply_branding">
                <t t-out="0"/>
            </t>
            <t t-else="">
                <div class="crb-report-root crb-article-inner" t-att-style="company.crb_get_article_wrapper_style()">
                    <t t-out="0"/>
                </div>
            </t>
        </xpath>
        <xpath expr="//div[hasclass('o_footer_content') and hasclass('d-flex') and hasclass('border-top')]/div[@t-field='company.report_footer']" position="replace">
            <t t-if="not crb_apply_branding">
                <div class="flex-grow-1 text-start me-2" t-field="company.report_footer"/>
            </t>
            <t t-else="">
                <t t-if="company.crb_footer_mode == 'standard'">
                    <div class="flex-grow-1 text-start me-2" t-field="company.report_footer"/>
                </t>
                <t t-elif="company.crb_footer_mode == 'custom'">
                    <div class="flex-grow-1 text-start me-2" t-out="company.crb_footer_html"/>
                </t>
                <t t-else="">
                    <div class="flex-grow-1 text-start me-2"/>
                </t>
            </t>
        </xpath>
    </template>

